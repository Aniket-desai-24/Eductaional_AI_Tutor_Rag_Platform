APP_NAME=EDU-RAG
DEBUG=false
SECRET_KEY=change-me-please-min-32-chars

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/edurag

GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
VISION_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=edu-rag

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=edu-rag-documents
AWS_REGION=us-east-1

SHORT_TERM_TTL_SECONDS=1800
MAX_CONVERSATION_TURNS=10
MEMORY_SUMMARY_EVERY_N_TURNS=5

TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
CHUNK_SIZE=256
PARENT_CHUNK_SIZE=1024
CHUNK_OVERLAP=32

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
